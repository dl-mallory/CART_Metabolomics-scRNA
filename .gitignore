# Raw reads: too large to distribute. See data/fastq/README.md.
data/fastq/*.fastq.gz

# Serialised R objects; regenerated by run_all.sh. The same data is committed as
# CSV under results/tables/ and results/matrices/, which ARE tracked.
results/objects/
logs/

# The staged BD Rhapsody counts (data/bd_pipeline_out/) and the pinned msigdbr
# library (env/rlib/) ARE tracked deliberately -- they are what make the repo
# runnable and the GSEA reproducible. Do not add them here.

.Rhistory
.RData
.Rproj.user
.DS_Store
